/* ============================================================
 * OCWS Firefox Theme — Glassmorphic Desktop Environment
 * Generated by theme-engine from {{THEME_NAME}}
 *
 * Place in: ~/.mozilla/firefox/<profile>/chrome/userChrome.css
 * Enable: about:config → toolkit.legacyUserProfileCustomizations.stylesheets = true
 * ============================================================ */

@namespace url("http://www.mozilla.org/keymaster/gatekeeper/there.is.only.xul");

/* === OCWS Color Variables === */
:root {
  --ocws-bg: {{COLOR_BG}};
  --ocws-fg: {{COLOR_FG}};
  --ocws-surface0: {{COLOR_SURFACE0}};
  --ocws-surface1: {{COLOR_SURFACE}};
  --ocws-surface2: {{COLOR_BORDER}};
  --ocws-accent: {{COLOR_ACCENT}};
  --ocws-urgent: {{COLOR_URGENT}};
  --ocws-muted: {{COLOR_MUTED}};
  --ocws-mantle: {{COLOR_MANTLE}};
  --ocws-crust: {{COLOR_CRUST}};
  --ocws-overlay0: {{COLOR_OVERLAY0}};
  --ocws-blue: {{COLOR_BLUE}};
  --ocws-green: {{COLOR_OK}};
  --ocws-yellow: {{COLOR_YELLOW}};
  --ocws-red: {{COLOR_URGENT}};
  --ocws-mauve: {{COLOR_MAUVE}};
  --ocws-teal: {{COLOR_TEAL}};

  --ocws-corner: {{CORNER_RADIUS}}px;
  --ocws-alpha-bg: alpha/{{COLOR_BG}}cc;
  --ocws-alpha-surface: alpha/{{COLOR_SURFACE0}}cc;
}

/* === Force Dark Mode === */
@media (prefers-color-scheme: light) {
  :root {
    color-scheme: dark !important;
  }
}

/* === Tab Bar === */
#TabsToolbar {
  background: var(--ocws-bg) !important;
  border-bottom: 1px solid var(--ocws-fg) !important;
  padding: 0 4px !important;
}

.tab-background {
  border-radius: var(--ocws-corner) var(--ocws-corner) 0 0 !important;
  margin: 2px 1px 0 1px !important;
  padding: 4px 10px !important;
  background: transparent !important;
  border: 1px solid transparent !important;
  transition: all 150ms ease-out !important;
}

.tab-background:hover {
  background: var(--ocws-accent) !important;
  border-color: var(--ocws-accent) !important;
}

.tab-background[selected="true"] {
  background: var(--ocws-accent) !important;
  border-color: var(--ocws-accent) !important;
  border-bottom: 2px solid var(--ocws-accent) !important;
}

.tab-label {
  color: var(--ocws-fg) !important;
  font-size: 12px !important;
}

.tab-background[selected="true"] .tab-label {
  color: var(--ocws-accent) !important;
  font-weight: 600 !important;
}

/* Tab close button */
.tab-close-button {
  border-radius: 4px !important;
  padding: 2px !important;
}

.tab-close-button:hover {
  background: var(--ocws-urgent) !important;
}

/* New tab button */
#tabs-newtab-button {
  border-radius: var(--ocws-corner) !important;
  padding: 4px 8px !important;
}

#tabs-newtab-button:hover {
  background: var(--ocws-accent) !important;
}

/* === Navigation Bar === */
#nav-bar {
  background: var(--ocws-bg) !important;
  border-bottom: 1px solid var(--ocws-fg) !important;
  padding: 2px 6px !important;
  box-shadow: none !important;
}

/* URL Bar */
#urlbar {
  border-radius: var(--ocws-corner) !important;
  border: 1px solid var(--ocws-fg) !important;
  background: var(--ocws-surface0) !important;
  padding: 2px 8px !important;
  min-height: 32px !important;
}

#urlbar[focused="true"] {
  border-color: var(--ocws-accent) !important;
  box-shadow: 0 0 0 2px var(--ocws-accent) !important;
  background: var(--ocws-surface0) !important;
}

#urlbar-input {
  color: var(--ocws-fg) !important;
  font-size: 13px !important;
}

#urlbar-input::placeholder {
  color: var(--ocws-fg) !important;
}

/* URL bar results */
.urlbarView {
  background: var(--ocws-bg) !important;
  border: 1px solid var(--ocws-fg) !important;
  border-radius: 0 0 var(--ocws-corner) var(--ocws-corner) !important;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4) !important;
}

.urlbarView-row {
  padding: 6px 10px !important;
  border-radius: 4px !important;
  margin: 2px 4px !important;
}

.urlbarView-row:hover,
.urlbarView-row[selected] {
  background: var(--ocws-accent) !important;
}

.urlbarView-title {
  color: var(--ocws-fg) !important;
}

.urlbarView-url {
  color: var(--ocws-fg) !important;
}

/* === Buttons === */
toolbarbutton {
  border-radius: var(--ocws-corner) !important;
  padding: 4px 8px !important;
  color: var(--ocws-fg) !important;
  transition: all 150ms ease-out !important;
}

toolbarbutton:hover {
  background: var(--ocws-accent) !important;
  color: var(--ocws-accent) !important;
}

toolbarbutton:active {
  background: var(--ocws-accent) !important;
}

toolbarbutton[checked="true"] {
  background: var(--ocws-accent) !important;
  color: var(--ocws-accent) !important;
}

/* === Sidebar === */
#sidebar-box {
  background: var(--ocws-bg) !important;
  border-right: 1px solid var(--ocws-fg) !important;
}

#sidebar-header {
  background: var(--ocws-surface0) !important;
  border-bottom: 1px solid var(--ocws-fg) !important;
  padding: 8px 12px !important;
}

#sidebar-header .sidebar-header-title {
  color: var(--ocws-fg) !important;
  font-weight: 600 !important;
}

#sidebar {
  background: var(--ocws-bg) !important;
  color: var(--ocws-fg) !important;
}

.sidebar-item:hover {
  background: var(--ocws-accent) !important;
}

.sidebar-item[selected] {
  background: var(--ocws-accent) !important;
  color: var(--ocws-accent) !important;
}

/* === Context Menus === */
menu, menupopup, .menu-provider {
  background: var(--ocws-bg) !important;
  border: 1px solid var(--ocws-fg) !important;
  border-radius: var(--ocws-corner) !important;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4) !important;
  padding: 4px !important;
}

menuitem, menu {
  border-radius: 4px !important;
  padding: 4px 12px !important;
  color: var(--ocws-fg) !important;
}

menuitem:hover, menu:hover {
  background: var(--ocws-accent) !important;
}

menuitem[disabled="true"] {
  color: var(--ocws-fg) !important;
}

/* === Bookmarks Toolbar === */
#PersonalToolbar {
  background: var(--ocws-bg) !important;
  border-bottom: 1px solid var(--ocws-fg) !important;
  padding: 2px 6px !important;
}

toolbarbutton.bookmark-item {
  border-radius: 4px !important;
  padding: 2px 8px !important;
}

toolbarbutton.bookmark-item:hover {
  background: var(--ocws-accent) !important;
}

/* === Status Bar === */
#status-bar {
  background: var(--ocws-bg) !important;
  border-top: 1px solid var(--ocws-fg) !important;
  padding: 2px 8px !important;
}

#status-text {
  color: var(--ocws-fg) !important;
  font-size: 11px !important;
}

/* === Scrollbars === */
* {
  scrollbar-color: var(--ocws-fg) transparent !important;
  scrollbar-width: thin !important;
}

*:hover {
  scrollbar-color: var(--ocws-fg) transparent !important;
}

/* === Find Bar === */
#find-bar {
  background: var(--ocws-bg) !important;
  border-bottom: 1px solid var(--ocws-fg) !important;
  padding: 4px 8px !important;
}

#findbar-container textbox {
  border-radius: var(--ocws-corner) !important;
  border: 1px solid var(--ocws-fg) !important;
  background: var(--ocws-surface0) !important;
  color: var(--ocws-fg) !important;
  padding: 4px 8px !important;
}

/* === Developer Tools === */
#devtools-toolbox {
  border-top: 1px solid var(--ocws-fg) !important;
}

/* === Selection === */
::selection {
  background: var(--ocws-accent) !important;
  color: var(--ocws-fg) !important;
}

/* === Focus Ring === */
:focus-visible {
  outline: 2px solid var(--ocws-accent) !important;
  outline-offset: 2px !important;
}

/* === Fullscreen === */
#fullscr-toggler {
  background: var(--ocws-bg) !important;
  padding: 8px !important;
}

/* === Print Preview === */
#print-preview-toolbar {
  background: var(--ocws-bg) !important;
  border-bottom: 1px solid var(--ocws-fg) !important;
}

/* === Notification Popups === */
.popup-notification-body {
  background: var(--ocws-bg) !important;
  color: var(--ocws-fg) !important;
}

.popup-notification-button-container button {
  border-radius: var(--ocws-corner) !important;
  padding: 4px 12px !important;
}

