/* GTK3 + GTK4 CSS overrides — generated by theme-engine */
/* From: {{THEME_NAME}} */

/* Round corners on windows and dialogs */
window, .window, dialog, .dialog,
messagedialog, .messagedialog,
filechooser, .filechooser {
  border-radius: {{CORNER_RADIUS}}px;
}

/* Round corners on popovers and menus */
popover, menu, .menu, .popover,
.context-menu {
  border-radius: {{CORNER_RADIUS}}px;
  padding: 4px;
}

/* Softer button corners */
button, .button {
  border-radius: {{CORNER_RADIUS}}px;
  padding: 4px 10px;
}

/* Entry fields */
entry, .entry {
  border-radius: {{CORNER_RADIUS}}px;
}

/* Scrollbar styling */
scrollbar, scrollbar slider {
  border-radius: 4px;
  min-width: 6px;
}

scrollbar slider {
  min-height: 30px;
}

/* Selection */
selection {
  border-radius: 3px;
}

/* Tooltips */
tooltip {
  border-radius: {{CORNER_RADIUS}}px;
  padding: 4px 8px;
}

/* Notebook tabs */
notebook tab {
  border-radius: {{CORNER_RADIUS}}px {{CORNER_RADIUS}}px 0 0;
  padding: 4px 12px;
}

/* Header bar compact */
headerbar {
  padding: 2px 6px;
  min-height: 36px;
}

/* Sidebar */
sidebar {
  border-radius: 0;
}

/* Tree/List view */
treeview {
  border-radius: 4px;
}

/* Progress bar */
progressbar trough {
  border-radius: 4px;
  min-height: 4px;
}

progressbar progress {
  border-radius: 4px;
}

/* Switch */
switch {
  border-radius: 12px;
}

switch slider {
  border-radius: 12px;
}

/* Remove double border in headerbars */
headerbar:disabled {
  background: transparent;
}
