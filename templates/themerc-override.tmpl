# Theme overrides for labwc — generated by theme-engine
# From: {{THEME_NAME}}

# Active window title
window.active.label.text.color: {{THEMERC_ACTIVE_TEXT}}
window.active.title.bg: Solid
window.active.title.bg.color: {{THEMERC_ACTIVE_BG}}
window.active.border.color: {{THEMERC_BORDER}}

# Inactive window title
window.inactive.label.text.color: {{THEMERC_INACTIVE_TEXT}}
window.inactive.title.bg: Solid
window.inactive.title.bg.color: {{THEMERC_INACTIVE_BG}}
window.inactive.border.color: {{THEMERC_BORDER}}

# Window borders
border.width: {{BORDER_WIDTH}}

# Titlebar
titlebar.height: {{THEMERC_HEIGHT}}
titlebar_layout: {{TITLEBAR_LAYOUT}}

# Menu
menu.items.bg.color: {{OSD_BG}}
menu.items.text.color: {{OSD_TEXT}}
menu.items.active.bg.color: {{THEMERC_ACTIVE_BG}}
menu.items.active.text.color: {{OSD_TEXT}}
menu.title.bg.color: {{OSD_ACCENT}}
menu.title.text.color: {{OSD_TEXT}}
menu.border.color: {{OSD_BORDER}}

# OSD / Window Switcher (Alt+Tab)
osd.bg.color: {{OSD_BG}}
osd.border.color: {{OSD_BORDER}}
osd.border.width: 2
osd.label.text.color: {{OSD_TEXT}}

# Window switcher - classic style
osd.window-switcher.style-classic.width: 600
osd.window-switcher.style-classic.padding: 8
osd.window-switcher.style-classic.item.padding.x: 12
osd.window-switcher.style-classic.item.padding.y: 4
osd.window-switcher.style-classic.item.icon.size: 24
osd.window-switcher.style-classic.item.active.bg.color: {{OSD_BG}}
osd.window-switcher.style-classic.item.active.text.color: {{OSD_TEXT}}
osd.window-switcher.style-classic.item.active.border.width: 2
osd.window-switcher.style-classic.item.active.border.color: {{OSD_ACCENT}}

# Workspace switcher (Super+Number)
osd.workspace-switcher.boxes.width: 24
osd.workspace-switcher.boxes.height: 24
osd.workspace-switcher.boxes.border.width: 2
osd.workspace-switcher.boxes.bg.color: {{OSD_BG}}
osd.workspace-switcher.boxes.border.color: {{OSD_BORDER}}
osd.workspace-switcher.boxes.active.bg.color: {{OSD_ACCENT}}
osd.workspace-switcher.boxes.active.border.color: {{OSD_ACCENT}}
osd.workspace-switcher.label.text.color: {{OSD_TEXT}}

# Window button colors
window.active.button.unpressed.image.color: {{OSD_TEXT}}
window.inactive.button.unpressed.image.color: {{OSD_INACTIVE}}
