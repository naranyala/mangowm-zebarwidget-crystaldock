# tmux config — generated by theme-engine
# From: {{THEME_NAME}}

## easy to reload
bind r source-file ~/.tmux.conf \; display-message "Config reloaded!"

set -g extended-keys on
set -g extended-keys-format csi-u

## align with panel position
set -g status-position top
set -g mouse on

## better super key
unbind C-b
set-option -g prefix C-Space
bind-key C-Space send-prefix

## reset index one
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on

## remember last dir path
bind c new-window -c "#{pane_current_path}"
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

## Ctrl+Arrow → switch focus between windows
bind-key -n C-Left  previous-window
bind-key -n C-Right next-window

## Ctrl+Shift+Arrow → move window left or right
bind-key -n C-S-Left  swap-window -t -1 \; select-window -t -1
bind-key -n C-S-Right swap-window -t +1 \; select-window -t +1

## theme
set -g status-style bg={{TMUX_STATUS_BG}},fg={{TMUX_STATUS_FG}}
setw -g window-status-current-style bg={{TMUX_ACCENT}},fg={{TMUX_ACCENT_FG}},bold
setw -g window-status-format "#I:#W"
set -g window-status-current-format "#I:#W"
