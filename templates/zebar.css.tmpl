/* Zebar statusbar CSS — generated by theme-engine */
/* From: {{THEME_NAME}} */

@import 'https://www.nerdfonts.com/assets/css/webfont.css';

:root {
  --bg: {{COLOR_BG}}{{BG_ALPHA}};
  --fg: {{COLOR_FG}};
  --accent: {{COLOR_ACCENT}};
  --green: {{COLOR_OK}};
  --red: {{COLOR_URGENT}};
  --yellow: {{COLOR_WARNING}};
  --teal: {{COLOR_TEAL}};
  --surface: {{COLOR_SURFACE}}{{SURFACE_ALPHA}};
  --surface-hover: {{COLOR_SURFACE}}99;
  --text-muted: {{COLOR_MUTED}};
  --border: {{COLOR_BORDER}}{{BORDER_ALPHA}};
}

html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }

body {
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
  font-size: {{FONT_SIZE}}px;
  color: var(--fg);
  background: transparent;
}

#root {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 12px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  gap: 4px;
}

/* ============== Workspaces ============== */

.workspaces {
  display: flex;
  gap: 3px;
  margin-right: 12px;
}

.ws-btn {
  padding: 2px 8px;
  border-radius: 4px;
  border: none;
  background: var(--surface);
  color: var(--text-muted);
  font-size: {{FONT_SIZE_SMALL}}px;
  cursor: pointer;
  transition: all 0.15s ease;
  min-width: 24px;
  text-align: center;
}

.ws-btn:hover { background: var(--surface-hover); color: var(--fg); }
.ws-btn.active { background: var(--accent); color: {{COLOR_BG}}; font-weight: 700; }
.ws-btn.occupied { color: var(--fg); }

/* ============== Segments ============== */

.segment { display: flex; align-items: center; gap: 6px; }
.left { flex: 1; display: flex; align-items: center; gap: 4px; }
.center { flex: 1; display: flex; align-items: center; justify-content: center; }
.right { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 4px; }

/* ============== Modules ============== */

.module {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: {{MODULE_PADDING_V}}px {{MODULE_PADDING_H}}px;
  border-radius: {{MODULE_RADIUS}}px;
  background: var(--surface);
  white-space: nowrap;
  transition: background 0.15s ease;
}

.module.clickable { cursor: pointer; }
.module.clickable:hover { background: var(--surface-hover); }

.module i { font-size: 13px; }

.module.clock { background: transparent; padding: 2px 4px; }
.module.clock .time { font-size: {{FONT_SIZE}}px; font-weight: 600; }
.module.clock .date { font-size: {{FONT_SIZE_SMALL}}px; color: var(--text-muted); margin-left: 6px; }

.module.cpu .val { color: var(--accent); }
.module.memory .val { color: var(--green); }
.module.disk .val { color: var(--teal); }

.module.network .ssid { max-width: 80px; overflow: hidden; text-overflow: ellipsis; }
.module.network .val { color: var(--accent); }
.module.network i { color: var(--accent); }

.module.battery i { color: var(--yellow); }
.module.battery.charging i { color: var(--green); }
.module.battery.low i { color: var(--red); }

.module.volume i { color: var(--teal); }
.module.volume.muted i { color: var(--red); }
.module.volume.muted .val { color: var(--red); }

.module.action i { color: var(--text-muted); cursor: pointer; }
.module.action:hover i { color: var(--fg); }

.module.weather i { color: var(--yellow); }

/* High-usage warnings */
.module.cpu.high .val { color: var(--yellow); }
.module.cpu.critical .val { color: var(--red); }
.module.memory.high .val { color: var(--yellow); }

/* Media */
.module.media { max-width: 180px; }
.module.media .title { overflow: hidden; text-overflow: ellipsis; color: var(--teal); }
.module.media .artist { font-size: {{FONT_SIZE_SMALL}}px; color: var(--text-muted); }

/* Tooltip-like */
.tooltip {
  display: none;
  position: absolute;
  top: 100%;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 8px;
  z-index: 100;
  font-size: {{FONT_SIZE_SMALL}}px;
  white-space: nowrap;
}

.module:hover .tooltip { display: block; }
