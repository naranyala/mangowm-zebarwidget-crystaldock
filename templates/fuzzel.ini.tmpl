# Fuzzel app launcher theme
# Generated by theme-engine from {{THEME_NAME}}

[main]
font=Noto Sans:size=14
dpi-aware=auto
icon-theme={{ICON_THEME}}
icons-enabled=yes
prompt=❯ 
placeholder=Type to search...
match-mode=fuzzy
sort-result=yes
anchor=center
width=40
lines=15
horizontal-pad=40
vertical-pad=8
layer=overlay
topmost=true
touchevents=true

[colors]
background={{COLOR_BG}}ff
text={{COLOR_FG}}ff
prompt={{COLOR_ACCENT}}ff
placeholder={{COLOR_MUTED}}ff
input={{COLOR_FG}}ff
match={{COLOR_ACCENT}}ff
selection={{COLOR_SURFACE}}22
selection-text={{COLOR_FG}}ff
selection-match={{COLOR_ACCENT}}ff
border={{COLOR_BORDER}}33
urgent={{COLOR_URGENT}}33

[border]
width=2
radius=12
