<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>
  <core>
    <decoration>server</decoration>
  </core>

  <theme>
    <name>Clearlooks</name>
    <font place="ActiveWindow">
      <name>sans</name>
      <size>10</size>
    </font>
    <font place="InactiveWindow">
      <name>sans</name>
      <size>10</size>
    </font>
    <font place="MenuHeader">
      <name>sans</name>
      <size>10</size>
    </font>
    <font place="MenuItem">
      <name>sans</name>
      <size>10</size>
    </font>
  </theme>

  <desktops>
    <number>9</number>
    <firstdesk>1</firstdesk>
  </desktops>

  <keyboard>
    <!-- System -->
    <keybind key="A-r"><action name="Reload"/></keybind>
    <keybind key="A-q"><action name="Close"/></keybind>
    <keybind key="A-F4"><action name="Close"/></keybind>
    <keybind key="S-m"><action name="Exit"/></keybind>

    <!-- Launchers -->
    <keybind key="A-Return"><action name="Execute"><command>contour</command></action></keybind>
    <keybind key="A-d"><action name="Execute"><command>rofi -show drun</command></action></keybind>

    <!-- Window management -->
    <keybind key="A-e"><action name="ToggleFloating"/></keybind>
    <keybind key="A-f"><action name="ToggleFullscreen"/></keybind>
    <keybind key="S-a"><action name="ToggleMaximize"/></keybind>
    <keybind key="A-space"><action name="ShowMenu"><menu>root-menu</menu></action></keybind>

    <!-- Focus -->
    <keybind key="A-Left"><action name="Focus"><direction>left</direction></action></keybind>
    <keybind key="A-Right"><action name="Focus"><direction>right</direction></action></keybind>
    <keybind key="A-Up"><action name="Focus"><direction>up</direction></action></keybind>
    <keybind key="A-Down"><action name="Focus"><direction>down</direction></action></keybind>

    <!-- Window movement -->
    <keybind key="S-A-Left"><action name="Swap"><direction>left</direction></action></keybind>
    <keybind key="S-A-Right"><action name="Swap"><direction>right</direction></action></keybind>
    <keybind key="S-A-Up"><action name="Swap"><direction>up</direction></action></keybind>
    <keybind key="S-A-Down"><action name="Swap"><direction>down</direction></action></keybind>

    <!-- Resize with arrow keys -->
    <keybind key="S-Left"><action name="Unsnap"/><action name="Resize"><direction>left</direction><size>40px</size></action></keybind>
    <keybind key="S-Right"><action name="Unsnap"/><action name="Resize"><direction>right</direction><size>40px</size></action></keybind>
    <keybind key="S-Up"><action name="Unsnap"/><action name="Resize"><direction>up</direction><size>40px</size></action></keybind>
    <keybind key="S-Down"><action name="Unsnap"/><action name="Resize"><direction>down</direction><size>40px</size></action></keybind>

    <!-- Desktops -->
    <keybind key="W-1"><action name="GoToDesktop"><to>1</to></action></keybind>
    <keybind key="W-2"><action name="GoToDesktop"><to>2</to></action></keybind>
    <keybind key="W-3"><action name="GoToDesktop"><to>3</to></action></keybind>
    <keybind key="W-4"><action name="GoToDesktop"><to>4</to></action></keybind>
    <keybind key="W-5"><action name="GoToDesktop"><to>5</to></action></keybind>
    <keybind key="W-6"><action name="GoToDesktop"><to>6</to></action></keybind>
    <keybind key="W-7"><action name="GoToDesktop"><to>7</to></action></keybind>
    <keybind key="W-8"><action name="GoToDesktop"><to>8</to></action></keybind>
    <keybind key="W-9"><action name="GoToDesktop"><to>9</to></action></keybind>

    <!-- Send window to desktop -->
    <keybind key="S-A-1"><action name="SendToDesktop"><to>1</to></action></keybind>
    <keybind key="S-A-2"><action name="SendToDesktop"><to>2</to></action></keybind>
    <keybind key="S-A-3"><action name="SendToDesktop"><to>3</to></action></keybind>
    <keybind key="S-A-4"><action name="SendToDesktop"><to>4</to></action></keybind>
    <keybind key="S-A-5"><action name="SendToDesktop"><to>5</to></action></keybind>
    <keybind key="S-A-6"><action name="SendToDesktop"><to>6</to></action></keybind>
    <keybind key="S-A-7"><action name="SendToDesktop"><to>7</to></action></keybind>
    <keybind key="S-A-8"><action name="SendToDesktop"><to>8</to></action></keybind>
    <keybind key="S-A-9"><action name="SendToDesktop"><to>9</to></action></keybind>

    <!-- Gaps -->
    <keybind key="A-comma"><action name="SetGap"><amount>+5</amount><side>all</side></action></keybind>
    <keybind key="A-period"><action name="SetGap"><amount>-5</amount><side>all</side></action></keybind>

    <!-- Media keys -->
    <keybind key="XF86AudioRaiseVolume"><action name="Execute"><command>wpctl set-volume @DEFAULT_SINK@ 5%+</command></action></keybind>
    <keybind key="XF86AudioLowerVolume"><action name="Execute"><command>wpctl set-volume @DEFAULT_SINK@ 5%-</command></action></keybind>
    <keybind key="XF86AudioMute"><action name="Execute"><command>wpctl set-mute @DEFAULT_SINK@ toggle</command></action></keybind>
    <keybind key="XF86AudioPlay"><action name="Execute"><command>playerctl play-pause</command></action></keybind>
    <keybind key="XF86AudioNext"><action name="Execute"><command>playerctl next</command></action></keybind>
    <keybind key="XF86AudioPrev"><action name="Execute"><command>playerctl previous</command></action></keybind>

    <!-- Screenshots -->
    <keybind key="Print"><action name="Execute"><command>grim -g "$(slurp)" - | wl-copy</command></action></keybind>
    <keybind key="A-Print"><action name="Execute"><command>grim - | wl-copy</command></action></keybind>
    <keybind key="S-Print"><action name="Execute"><command>grim - | wl-copy</command></action></keybind>
    <keybind key="C-Print"><action name="Execute"><command>grim -g "$(slurp -w)" - | wl-copy</command></action></keybind>
    <keybind key="S-A-Print"><action name="Execute"><command>screenshot.sh annotate</command></action></keybind>
    <keybind key="S-C-Print"><action name="Execute"><command>screenshot.sh annotate-full</command></action></keybind>

    <!-- Clipboard -->
    <keybind key="S-v"><action name="Execute"><command>cliphist list | rofi -dmenu | cliphist decode | wl-copy</command></action></keybind>

    <!-- Quick Settings -->
    <keybind key="C-S-n"><action name="Execute"><command>~/.config/labwc/autostart &amp; gammastep -m randr -t 6500:3500 -g 1.0 -r || pkill -x gammastep</command></action></keybind>

    <!-- App Launcher Variants -->
    <keybind key="A-Tab"><action name="NextWindow"/></keybind>
    <keybind key="A-S-Tab"><action name="PreviousWindow"/></keybind>
    <keybind key="A-x"><action name="Execute"><command>rofi -show run -theme-str 'window {width: 500px;}'</command></action></keybind>

    <!-- Calculator -->
    <keybind key="A-c"><action name="Execute"><command>rofi -e "$(echo | bc -l)" -theme-str 'window {width: 300px;}'</command></action></keybind>

    <!-- Power Menu -->
    <keybind key="A-F5"><action name="Execute"><command>~/.config/labwc/scripts/actions/power-menu.sh</command></action></keybind>

    <!-- Emoji Picker -->
    <keybind key="A-period"><action name="Execute"><command>rofi -e "Emoji Picker: Use rofi to select emoji" -theme-str 'window {width: 400px;}'</command></action></keybind>

    <!-- Window Snapping -->
    <keybind key="C-A-Left"><action name="Execute"><command>~/.config/labwc/scripts/actions/window.sh snap-left</command></action></keybind>
    <keybind key="C-A-Right"><action name="Execute"><command>~/.config/labwc/scripts/actions/window.sh snap-right</command></action></keybind>
    <keybind key="C-A-Up"><action name="Execute"><command>~/.config/labwc/scripts/actions/window.sh snap-top</command></action></keybind>
    <keybind key="C-A-Down"><action name="Execute"><command>~/.config/labwc/scripts/actions/window.sh snap-bottom</command></action></keybind>

    <!-- Workspace Navigation -->
    <keybind key="A-Left"><action name="GoToDesktop"><to>left</to><wrap>yes</wrap></action></keybind>
    <keybind key="A-Right"><action name="GoToDesktop"><to>right</to><wrap>yes</wrap></action></keybind>

    <!-- Network/WiFi Toggle -->
    <keybind key="XF86LaunchA"><action name="Execute"><command>nmcli radio wifi</command></action></keybind>

    <!-- Bluetooth Toggle -->
    <keybind key="XF86LaunchB"><action name="Execute"><command>bluetoothctl power on || bluetoothctl power off</command></action></keybind>

    <!-- Brightness -->
    <keybind key="XF86MonBrightnessUp"><action name="Execute"><command>brightnessctl set +10%</command></action></keybind>
    <keybind key="XF86MonBrightnessDown"><action name="Execute"><command>brightnessctl set 10%-</command></action></keybind>

    <!-- Window Management Extras -->
    <keybind key="S-Return"><action name="Execute"><command>contour</command></action></keybind>
    <keybind key="A-BackSpace"><action name="Execute"><command>rofi -show window -theme-str 'window {width: 500px;}'</command></action></keybind>

    <!-- Theme Switcher -->
    <keybind key="A-F12"><action name="Execute"><command>theme next</command></action></keybind>
    <keybind key="A-S-F12"><action name="Execute"><command>theme</command></action></keybind>
  </keyboard>

  <mouse>
    <context name="Frame">
      <mousebind button="A-Left" action="Drag">
        <action name="Move"/>
      </mousebind>
    </context>
    <context name="Titlebar">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="Left" action="DoubleClick">
        <action name="ToggleMaximize"/>
      </mousebind>
    </context>
    <context name="Client">
      <mousebind button="A-Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="A-Right" action="Drag">
        <action name="Resize"/>
      </mousebind>
    </context>
    <context name="Root">
      <mousebind button="Left" action="Press">
        <action name="ShowMenu"><menu>root-menu</menu></action>
      </mousebind>
    </context>
  </mouse>

  <applications>
    <!-- crystal-dock: layer shell, bottom, full width -->
    <application class="crystal-dock">
      <skip_taskbar>yes</skip_taskbar>
      <skip_pager>yes</skip_pager>
      <fixed_position>yes</fixed_position>
    </application>
  </applications>

  <menu id="root-menu" label="Root Menu">
    <item label="Terminal">
      <action name="Execute"><command>contour</command></action>
    </item>
    <item label="Rofi Launcher">
      <action name="Execute"><command>rofi -show drun</command></action>
    </item>
    <item label="Wallpaper (Random)">
      <action name="Execute"><command>wallpaper random</command></action>
    </item>
    <item label="Reload Config">
      <action name="Reload"/>
    </item>
    <item label="Exit labwc">
      <action name="Exit"/>
    </item>
  </menu>
</labwc_config>
