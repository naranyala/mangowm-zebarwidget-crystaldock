#!/bin/sh
#
# labwc autostart — runs once at compositor startup
#
# Default shell: dms
# Alternative:   noctalia, crystal-dock, sfwbar (use toggle-shell to switch)
#

# Ensure local binaries are in PATH
export PATH="$HOME/.local/bin:$PATH"

# --- DBus Update (critical for portals & screensharing) ---
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd --all
fi
if command -v systemctl >/dev/null 2>&1; then
  systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
  killall -q xdg-desktop-portal xdg-desktop-portal-wlr xdg-desktop-portal-gtk 2>/dev/null || true
fi

# --- Touchpad natural scroll ---
if command -v gsettings >/dev/null 2>&1; then
  gsettings set org.gnome.desktop.peripherals.touchpad natural-scroll true 2>/dev/null
fi

# --- Wallpaper ---
if command -v wallpaper >/dev/null 2>&1; then
  wallpaper random &
elif command -v swaybg >/dev/null 2>&1; then
  WP_DIR="$HOME/Pictures/wallpapers"
  if [ -d "$WP_DIR" ]; then
    WP_FILE=$(find "$WP_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) 2>/dev/null | shuf -n 1)
    if [ -n "$WP_FILE" ]; then
      swaybg -i "$WP_FILE" -m fill &
    fi
  fi
fi

# --- Shell Mode Selection ---
# Uses toggle-shell to start the configured shell mode
if command -v toggle-shell >/dev/null 2>&1; then
  # Check for environment variable first, then config file, else default
  if [ -n "${LABWC_SHELL_MODE:-}" ]; then
    toggle-shell "$LABWC_SHELL_MODE"
  elif [ -f "$HOME/.config/ocws/mode" ]; then
    MODE="$(cat "$HOME/.config/ocws/mode")"
    toggle-shell "$MODE"
  elif [ -f "$HOME/.config/labwc-widgets/shell-mode" ]; then
    MODE="$(cat "$HOME/.config/labwc-widgets/shell-mode")"
    toggle-shell "$MODE"
  else
    toggle-shell dms
  fi
elif command -v shell-switcher.sh >/dev/null 2>&1; then
  shell-switcher.sh
else
  echo "warning: no shell switcher found, starting dms directly"
  if command -v dms >/dev/null 2>&1; then
    nohup dms > /dev/null 2>&1 &
  elif command -v sfwbar >/dev/null 2>&1; then
    nohup sfwbar -f "$HOME/.config/ocws/ocws.config" > /dev/null 2>&1 &
  fi
fi

# --- Notification daemon ---
if command -v mako >/dev/null 2>&1; then
  mako &
elif command -v dunst >/dev/null 2>&1; then
  dunst &
fi

# --- Clipboard manager ---
pkill -f "wl-paste.*cliphist" 2>/dev/null || true
pkill -f "wl-paste.*watch" 2>/dev/null || true
sleep 0.1

if command -v cliphist >/dev/null 2>&1; then
  wl-paste --type text/plain --watch cliphist store 2>/dev/null &
  wl-paste --type image --watch cliphist store 2>/dev/null &
elif command -v wl-paste >/dev/null 2>&1; then
  if ! pgrep -f "wl-paste" >/dev/null 2>&1; then
    wl-paste --type text/plain --watch cat >/dev/null 2>&1 &
  fi
fi

# --- Screen protection ---
if command -v gammastep >/dev/null 2>&1; then
  gammastep -t 6500:3500 -g 1.0 -r &
elif command -v redshift >/dev/null 2>&1; then
  redshift -t 6500:3500 -g 1.0 -r &
fi

# --- Authentication & Keyring ---
if command -v gnome-keyring-daemon >/dev/null 2>&1; then
  gnome-keyring-daemon --start --components=secrets,ssh,pkcs11 &
fi

# --- Idle & Screen Locker ---
if command -v swayidle >/dev/null 2>&1; then
  swayidle -w \
    timeout 300 'swaylock -f -c 000000' \
    timeout 360 'wlr-randr --output eDP-1 --off' resume 'wlr-randr --output eDP-1 --on' \
    before-sleep 'swaylock -f -c 000000' &
fi

# --- Screenshot daemon ---
if command -v flameshot >/dev/null 2>&1; then
  pkill -x flameshot 2>/dev/null || true
  sleep 0.1
  flameshot &
fi

# --- Autorun Programs ---
if command -v ocws-autorun.sh >/dev/null 2>&1; then
  ocws-autorun.sh &
elif [ -f "$HOME/.config/labwc/autorun.conf" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    line="$(echo "$line" | sed 's/#.*//' | xargs)"
    [ -z "$line" ] && continue
    nohup $line > /dev/null 2>&1 &
  done < "$HOME/.config/labwc/autorun.conf"
fi
