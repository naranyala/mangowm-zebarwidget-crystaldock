#!/bin/sh
#
# labwc autostart — runs once at compositor startup
#
# Default shell: noctalia
# Alternative:   dms, crystal-dock, sfwbar (use toggle-shell to switch)
#

# Ensure local and package manager binaries are in PATH
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/go/bin:$HOME/.npm-global/bin:$HOME/.bun/bin:$PATH"

# --- DBus Update (critical for portals & screensharing) ---
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd --all
fi
if command -v systemctl >/dev/null 2>&1; then
  systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
fi

# --- XDG Desktop Portal ---
# Clean crystal-dock IPC artifacts to prevent startup failures on soft-reboots
rm -f /tmp/qipc_sharedmemory_* /tmp/qipc_systemsem_* /dev/shm/qipc_sharedmemory_* /dev/shm/qipc_systemsem_* 2>/dev/null

# Kill stale portals, then start fresh instances
killall -q xdg-desktop-portal xdg-desktop-portal-wlr xdg-desktop-portal-gtk 2>/dev/null || true
sleep 0.2
if command -v xdg-desktop-portal >/dev/null 2>&1; then
  xdg-desktop-portal &
fi
if command -v xdg-desktop-portal-wlr >/dev/null 2>&1; then
  xdg-desktop-portal-wlr &
fi

# --- Touchpad natural scroll ---
if command -v gsettings >/dev/null 2>&1; then
  gsettings set org.gnome.desktop.peripherals.touchpad natural-scroll true 2>/dev/null
fi

# --- Wallpaper ---
if command -v wallpaper >/dev/null 2>&1; then
  wallpaper auto &
elif command -v swaybg >/dev/null 2>&1; then
  WP_DIR="$HOME/Pictures/wallpapers"
  if [ -d "$WP_DIR" ]; then
    WP_FILE=$(find "$WP_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) 2>/dev/null | shuf -n 1)
    if [ -n "$WP_FILE" ]; then
      swaybg -i "$WP_FILE" -m fill &
    fi
  fi
fi

# --- Shell Mode Selection ---
# Uses toggle-shell to start the configured shell mode.
# Default mode is "tworow": lxqt-panel docked at the top (Wayland /
# layer-shell) plus the OCWS 2-row sfwbar taskbar docked at the bottom.

# Wait until the Wayland compositor is actually accepting clients, so the
# panels don't fail to connect on a slow startup and silently never appear.
wait_for_wayland() {
  local sock="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/${WAYLAND_DISPLAY:-wayland-0}"
  local tries=0
  while [ ! -S "$sock" ] && [ "$tries" -lt 50 ]; do
    sleep 0.2
    tries=$((tries + 1))
  done
}
wait_for_wayland

# Resolve the requested mode (env var > ocws mode file > legacy file > default)
MODE=""
if [ -n "${LABWC_SHELL_MODE:-}" ]; then
  MODE="$LABWC_SHELL_MODE"
elif [ -f "$HOME/.config/ocws/mode" ]; then
  MODE="$(cat "$HOME/.config/ocws/mode")"
elif [ -f "$HOME/.config/labwc-widgets/shell-mode" ]; then
  MODE="$(cat "$HOME/.config/labwc-widgets/shell-mode")"
fi
MODE="${MODE:-crystaldock}"

# Helper: start lxqt-panel only if it isn't already running.
start_lxqt_panel() {
  command -v lxqt-panel >/dev/null 2>&1 || return 0
  pgrep -x lxqt-panel >/dev/null 2>&1 && return 0
  # layer-shell integration is required for lxqt-panel to dock on labwc;
  # the wlroots token lets it pick the correct Wayland backend.
  QT_WAYLAND_SHELL_INTEGRATION=layer-shell \
    XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-labwc}:wlroots" \
    nohup lxqt-panel -c "$HOME/.config/lxqt/panel.conf" >/dev/null 2>&1 &
}

if command -v toggle-shell >/dev/null 2>&1; then
  toggle-shell "$MODE"
elif command -v shell-switcher.sh >/dev/null 2>&1; then
  shell-switcher.sh
else
  # Direct sfwbar launch — no toggle-shell available
  case "$MODE" in
    doublepanel|dual)
      nohup sfwbar -f "$HOME/.config/ocws/modes/dual.mode" > /dev/null 2>&1 &
      ;;
    crystaldock)
      nohup sfwbar -f "$HOME/.config/ocws/modes/crystaldock.mode" > /dev/null 2>&1 &
      if command -v crystal-dock >/dev/null 2>&1; then
        nohup crystal-dock >/dev/null 2>&1 &
      fi
      ;;
    minimal)
      nohup sfwbar -f "$HOME/.config/ocws/modes/minimal.mode" > /dev/null 2>&1 &
      ;;
    tworow)
      nohup sfwbar -f "$HOME/.config/ocws/modes/tworow.mode" > /dev/null 2>&1 &
      start_lxqt_panel
      ;;
    lxqt-classic)
      # Deploy lxqt-panel config
      if [ -f "$HOME/.config/lxqt/modes/classic.conf" ]; then
        cp "$HOME/.config/lxqt/modes/classic.conf" "$HOME/.config/lxqt/panel.conf"
      fi
      start_lxqt_panel
      nohup sfwbar -f "$HOME/.config/ocws/modes/lxqt-classic.mode" > /dev/null 2>&1 &
      ;;
    lxqt-minimal)
      if [ -f "$HOME/.config/lxqt/modes/minimal.conf" ]; then
        cp "$HOME/.config/lxqt/modes/minimal.conf" "$HOME/.config/lxqt/panel.conf"
      fi
      start_lxqt_panel
      nohup sfwbar -f "$HOME/.config/ocws/modes/lxqt-minimal.mode" > /dev/null 2>&1 &
      ;;
    lxqt-standalone)
      if [ -f "$HOME/.config/lxqt/modes/standalone.conf" ]; then
        cp "$HOME/.config/lxqt/modes/standalone.conf" "$HOME/.config/lxqt/panel.conf"
      fi
      start_lxqt_panel
      ;;
    lxqt-dual-lxqt)
      if [ -f "$HOME/.config/lxqt/modes/dual-lxqt.conf" ]; then
        cp "$HOME/.config/lxqt/modes/dual-lxqt.conf" "$HOME/.config/lxqt/panel.conf"
      fi
      start_lxqt_panel
      ;;
    lxqt-vertical)
      if [ -f "$HOME/.config/lxqt/modes/vertical.conf" ]; then
        cp "$HOME/.config/lxqt/modes/vertical.conf" "$HOME/.config/lxqt/panel.conf"
      fi
      start_lxqt_panel
      nohup sfwbar -f "$HOME/.config/ocws/modes/lxqt-vertical.mode" > /dev/null 2>&1 &
      ;;
    lxqt-bottom)
      if [ -f "$HOME/.config/lxqt/modes/bottom.conf" ]; then
        cp "$HOME/.config/lxqt/modes/bottom.conf" "$HOME/.config/lxqt/panel.conf"
      fi
      start_lxqt_panel
      nohup sfwbar -f "$HOME/.config/ocws/modes/lxqt-bottom.mode" > /dev/null 2>&1 &
      ;;
    dms)
      if command -v dms >/dev/null 2>&1; then
        nohup dms run > /dev/null 2>&1 &
      fi
      ;;
    noctalia)
      if command -v noctalia >/dev/null 2>&1; then
        nohup noctalia > /dev/null 2>&1 &
      fi
      ;;
    fltk-panel)
      if command -v fltk-panel >/dev/null 2>&1; then
        nohup fltk-panel > /dev/null 2>&1 &
      fi
      if command -v fltk-dock >/dev/null 2>&1; then
        nohup fltk-dock > /dev/null 2>&1 &
      fi
      ;;
    fltk-panel-zig)
      if command -v fltk-zig-shell >/dev/null 2>&1; then
        nohup fltk-zig-shell > /dev/null 2>&1 &
      fi
      ;;
    *)
      nohup sfwbar -f "$HOME/.config/ocws/modes/dual.mode" > /dev/null 2>&1 &
      ;;
  esac
fi

# --- Guarantee panels are running (re-run if the compositor was late) ---
# For lxqt-panel + sfwbar pairings, retry a few times so both are up even
# if labwc wasn't ready on the first launch attempt.
case "$MODE" in
  doublepanel|crystaldock|minimal)
    # Sfwbar-only modes — retry until sfwbar is up
    for _ in 1 2 3 4 5; do
      if pgrep -x sfwbar >/dev/null 2>&1; then
        break
      fi
      sleep 1
    done
    ;;
  tworow|lxqt-classic|lxqt-minimal|lxqt-vertical|lxqt-bottom)
    # Modes that pair lxqt-panel with sfwbar
    for _ in 1 2 3 4 5; do
      start_lxqt_panel
      if pgrep -x sfwbar >/dev/null 2>&1 && \
         { ! command -v lxqt-panel >/dev/null 2>&1 || pgrep -x lxqt-panel >/dev/null 2>&1; }; then
        break
      fi
      sleep 1
    done
    ;;
  lxqt-standalone|lxqt-dual-lxqt)
    # Modes with lxqt-panel only (no sfwbar)
    for _ in 1 2 3 4 5; do
      start_lxqt_panel
      if { ! command -v lxqt-panel >/dev/null 2>&1 || pgrep -x lxqt-panel >/dev/null 2>&1; }; then
        break
      fi
      sleep 1
    done
    ;;
esac

# --- OCWS State Daemon (event-driven IPC to sfwbar) ---
# Listens for volume/brightness/media changes and pushes them to sfwbar
# via ocws-emit. Self-retries until sfwbar is reachable on startup, and
# self-manages a PIDFILE so it won't collide with previous instances.
if [ -x "$HOME/.config/ocws/ocws-daemon.sh" ]; then
  nohup "$HOME/.config/ocws/ocws-daemon.sh" >/dev/null 2>&1 &
fi

# --- Bi-Directional Dock Sync Daemon ---
# Keeps pinned apps synchronized across DMS, Noctalia, Crystal-Dock, and SFWBar
if command -v dock-sync.py >/dev/null 2>&1; then
  pkill -f "python3.*dock-sync.py" 2>/dev/null || true
  nohup dock-sync.py >/dev/null 2>&1 &
elif [ -x "$HOME/.local/share/ocws/scripts/dock-sync.py" ]; then
  pkill -f "python3.*dock-sync.py" 2>/dev/null || true
  nohup "$HOME/.local/share/ocws/scripts/dock-sync.py" >/dev/null 2>&1 &
fi

# --- Touchpad Gesture Daemon ---
# Handles 3/4-finger swipes for window tiling and workspace switching
if [ -x "$HOME/.local/bin/ocws-gestured" ]; then
  pkill -f ocws-gestured 2>/dev/null || true
  nohup "$HOME/.local/bin/ocws-gestured" >> /tmp/ocws-gestured.log 2>&1 &
fi

# --- Notification daemon ---
if command -v swaync >/dev/null 2>&1; then
  swaync &
elif command -v mako >/dev/null 2>&1; then
  mako &
elif command -v dunst >/dev/null 2>&1; then
  dunst &
fi

# --- OSD (Volume / Brightness) ---
if command -v swayosd-server >/dev/null 2>&1; then
  swayosd-server &
fi

# --- Clipboard manager ---
pkill -f "wl-paste.*cliphist" 2>/dev/null || true
pkill -f "wl-paste.*watch" 2>/dev/null || true
sleep 0.1

if command -v cliphist >/dev/null 2>&1; then
  wl-paste --type text/plain --watch cliphist store 2>/dev/null &
  wl-paste --type image --watch cliphist store 2>/dev/null &
elif command -v wl-paste >/dev/null 2>&1; then
  if ! pgrep -f "wl-paste" >/dev/null 2>&1; then
    wl-paste --type text/plain --watch cat >/dev/null 2>&1 &
  fi
fi

# --- Screen protection ---
if command -v gammastep >/dev/null 2>&1; then
  gammastep -t 6500:3500 -g 1.0 -r &
elif command -v redshift >/dev/null 2>&1; then
  redshift -t 6500:3500 -g 1.0 -r &
fi

# --- Polkit Agent ---
if command -v /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1; then
  /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 &
elif command -v /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1; then
  /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
elif command -v polkit-agent-helper-1 >/dev/null 2>&1; then
  polkit-agent-helper-1 &
fi

# --- Authentication & Keyring ---
# Disabled: gnome-keyring-daemon causes a "login keyring" password popup
# on every session start. SSH agent is handled separately below.
# To re-enable: uncomment the block and run `seahorse` to set an empty password.
pkill -x gnome-keyring-daemon 2>/dev/null || true

# --- SSH Agent ---
# Use dedicated ssh-agent instead of gnome-keyring's ssh component.
# This avoids keyring password prompts for git over SSH.
if [ -z "$SSH_AUTH_SOCK" ] || [ ! -S "$SSH_AUTH_SOCK" ]; then
  eval "$(ssh-agent -s)" >/dev/null 2>&1
fi
# Auto-add keys if ssh-agent is running and keys exist
if command -v ssh-add >/dev/null 2>&1 && [ -n "$SSH_AUTH_SOCK" ]; then
  for key in "$HOME/.ssh/id_ed25519" "$HOME/.ssh/id_rsa"; do
    [ -f "$key" ] && ssh-add -q "$key" 2>/dev/null
  done
fi

# --- Idle & Screen Locker ---
# Read theme background color for lock screen
LOCK_COLOR="1e1e2e"
if [ -f "$HOME/.config/ocws/tokens.css" ]; then
  THEME_BG=$(grep -m1 '@define-color ocws_base' "$HOME/.config/ocws/tokens.css" 2>/dev/null | awk '{print $NF}' | tr -d ';')
  if [ -n "$THEME_BG" ]; then
    LOCK_COLOR="${THEME_BG#\#}"
  fi
fi

if command -v swayidle >/dev/null 2>&1; then
  swayidle -w \
    timeout 300 "swaylock -f -c ${LOCK_COLOR}" \
    timeout 360 'wlr-randr --output eDP-1 --off' resume 'wlr-randr --output eDP-1 --on' \
    before-sleep "swaylock -f -c ${LOCK_COLOR}" &
fi

# --- Screenshot daemon ---
if command -v flameshot >/dev/null 2>&1; then
  pkill -x flameshot 2>/dev/null || true
  sleep 0.1
  flameshot &
fi

# --- Autorun Programs ---
if command -v ocws-autorun.sh >/dev/null 2>&1; then
  ocws-autorun.sh &
elif [ -f "$HOME/.config/labwc/autorun.conf" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    line="$(echo "$line" | sed 's/#.*//' | xargs)"
    [ -z "$line" ] && continue
    nohup $line > /dev/null 2>&1 &
  done < "$HOME/.config/labwc/autorun.conf"
fi
