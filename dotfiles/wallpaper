#!/usr/bin/env bash
# dotfiles/wallpaper

WALLPAPER_DIR="${HOME}/Pictures/wallpapers"
# Look for sources file relative to script first (dev mode), then fall back to installed location
_script_dir="$(cd "$(dirname "$0")" && pwd)"
if [[ -f "$_script_dir/wallpaper-sources.txt" ]]; then
    SOURCES_FILE="$_script_dir/wallpaper-sources.txt"
elif [[ -f "$HOME/.config/ocws/wallpaper-sources.txt" ]]; then
    SOURCES_FILE="$HOME/.config/ocws/wallpaper-sources.txt"
else
    SOURCES_FILE="$HOME/.local/share/ocws/wallpaper-sources.txt"
fi

# --- Internal Functions ---

sync_wallpapers() {
    echo "Syncing wallpapers..."
    mkdir -p "$WALLPAPER_DIR"
    if [[ ! -f "$SOURCES_FILE" ]]; then
        echo "Error: $SOURCES_FILE not found."
        return 1
    fi

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^#.*$ ]] && continue
        [[ -z "$line" ]] && continue
        read -r type value <<< "$line"

        case "$type" in
            git)
                echo "  Syncing repo: $value"
                tmp_dir=$(mktemp -d)
                if git clone --depth 1 "$value" "$tmp_dir" 2>/dev/null; then
                    count=$(find "$tmp_dir" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) -exec cp -n {} "$WALLPAPER_DIR" \; -print | wc -l)
                    echo "    Copied $count wallpapers."
                else
                    echo "    Error: Could not clone $value"
                fi
                rm -rf "$tmp_dir"
                ;;
            zip)
                echo "  Downloading zip: $value"
                tmp_dir=$(mktemp -d)
                zip_file="$tmp_dir/archive.zip"
                if ! curl -sL "$value" -o "$zip_file"; then
                    echo "    Error: Download failed."
                    rm -rf "$tmp_dir"
                    continue
                fi
                if ! unzip -qo "$zip_file" -d "$tmp_dir" 2>/dev/null; then
                    echo "    Error: Failed to extract zip."
                    rm -rf "$tmp_dir"
                    continue
                fi
                count=$(find "$tmp_dir" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) -exec cp -n {} "$WALLPAPER_DIR" \; -print | wc -l)
                echo "    Copied $count wallpapers."
                rm -rf "$tmp_dir"
                ;;
            http|https)
                echo "  Downloading: $value"
                filename=$(echo "$value" | awk -F'/' '{print $NF}' | cut -d'?' -f1)
                [[ ! "$filename" =~ \.[a-zA-Z0-9]+$ ]] && filename="${filename}.jpg"
                if [[ -f "$WALLPAPER_DIR/$filename" ]]; then
                    echo "    Already exists, skipping."
                elif curl -sL "$value" -o "$WALLPAPER_DIR/$filename"; then
                    echo "    Saved as $filename."
                else
                    echo "    Error: Download failed."
                    rm -f "$WALLPAPER_DIR/$filename"
                fi
                ;;
        esac
    done < "$SOURCES_FILE"
    echo "Sync complete. ($(ls -1 "$WALLPAPER_DIR" | wc -l) wallpapers total)"
}

set_wallpaper() {
    local img="$1"
    if [[ -z "$img" ]]; then
        img=$(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) | shuf -n 1)
    fi
    [[ -z "$img" || ! -f "$img" ]] && { echo "Error: No wallpapers found in $WALLPAPER_DIR"; return 1; }

    img=$(realpath "$img")
    echo "Setting: $img"

    # 1. GNOME
    if [[ "$XDG_CURRENT_DESKTOP" == "GNOME" ]] || [[ "$XDG_CURRENT_DESKTOP" == *"GNOME"* ]]; then
        gsettings set org.gnome.desktop.background picture-uri "file://$img"
        gsettings set org.gnome.desktop.background picture-uri-dark "file://$img"

    # 2. Hyprland
    elif [[ "$XDG_CURRENT_DESKTOP" == "Hyprland" ]] || [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
        hyprctl hyprpaper preload "$img" && hyprctl hyprpaper wallpaper ",$img"

    # 3. Sway/labwc
    elif command -v swaybg >/dev/null 2>&1; then
        pkill -x swaybg 2>/dev/null
        sleep 0.05
        swaybg -i "$img" -m fill &

    # 4. swww (Generic Wayland)
    elif command -v swww >/dev/null 2>&1; then
        swww img "$img" --transition-type random

    # 5. feh (X11)
    elif command -v feh >/dev/null 2>&1; then
        feh --bg-fill "$img"

    # 6. nitrogen (X11)
    elif command -v nitrogen >/dev/null 2>&1; then
        nitrogen --set-geometry "$img"

    else
        echo "Error: No supported wallpaper setter found (try installing swaybg)."
        return 1
    fi

    # Trigger dynamic adaptive color palette based on wallpaper (if enabled)
    local project_dir
    project_dir="$(cd "$_script_dir/.." && pwd)"
    local current_theme=""
    if [[ -f "$HOME/.config/labwc/.current-theme" ]]; then
        current_theme=$(cat "$HOME/.config/labwc/.current-theme")
    fi

    if [[ "$current_theme" == "wallpaper-auto" ]]; then
        if [[ -x "$project_dir/scripts/wallpaper-theme.sh" && -x "$project_dir/scripts/theme-engine.sh" ]]; then
            echo "Generating adaptive color palette..."
            "$project_dir/scripts/wallpaper-theme.sh" "$img"
            
            local theme_file="$project_dir/themes/wallpaper-auto.ini"
            if [[ -f "$theme_file" ]]; then
                echo "Applying adaptive theme..."
                "$project_dir/scripts/theme-engine.sh" apply "$theme_file"
                
                # Reload UI components to reflect new theme
                command -v labwc >/dev/null 2>&1 && labwc -r 2>/dev/null || true
                pkill -USR1 sfwbar 2>/dev/null || true
                command -v makoctl >/dev/null 2>&1 && makoctl reload 2>/dev/null || true
                if pidof crystal-dock >/dev/null; then killall crystal-dock; sleep 0.1; crystal-dock & disown; fi
                
                # Update DankMaterialShell adaptive palette
                if pgrep -x dms >/dev/null; then
                    command -v dms >/dev/null 2>&1 && dms matugen queue --value "$img" --wait=false 2>/dev/null || true
                fi
                
                # Update Noctalia Shell adaptive palette
                if command -v noctalia >/dev/null 2>&1; then
                    mkdir -p ~/.config/noctalia
                    noctalia theme "$img" -o ~/.config/noctalia/theme.json 2>/dev/null || true
                    # If noctalia is running, notify it to reload (by touching config)
                    pgrep -x noctalia >/dev/null && touch ~/.config/noctalia/config.toml
                fi
                
                # Show notification popup with the new palette
                if command -v notify-send >/dev/null 2>&1; then
                    local t_bg=$(grep -m1 '^bg =' "$theme_file" | cut -d= -f2 | xargs)
                    local t_accent=$(grep -m1 '^accent =' "$theme_file" | cut -d= -f2 | xargs)
                    notify-send -a "Theme Engine" -i "$img" -t 5000 \
                        "Adaptive Palette Applied" \
                        "<b>Wallpaper:</b> $(basename "$img")\n<b>Background:</b> $t_bg\n<b>Accent:</b> $t_accent"
                fi
            fi
        fi
    fi
}

# --- Main Logic ---

case "${1:-}" in
    sync)
        sync_wallpapers
        ;;
    set)
        if [[ -n "$2" ]]; then
            set_wallpaper "$2"
        else
            echo "No path given, picking random wallpaper..."
            set_wallpaper
        fi
        ;;
    random)
        set_wallpaper
        ;;
    daemon)
        interval="${2:-3600}"
        echo "Starting wallpaper daemon (interval: ${interval}s)..."
        while true; do
            set_wallpaper
            sleep "$interval"
        done
        ;;
    *)
        echo "Usage: wallpaper {sync|set [path]|random|daemon [seconds]}"
        exit 1
        ;;
esac
