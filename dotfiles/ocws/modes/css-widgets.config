#Api2
# modes/css-widgets.config — Widget-specific CSS styles

#CSS

/* ============================================================
 * Module Buttons — pill style
 * ============================================================ */
button.module {
  padding: 0px 10px;
  border-radius: 18px;
  background-color: alpha(@theme_bg_color, 0.85);
  border: 1px solid @shell_border;
  box-shadow: 0 4px 16px @shadow;
  color: @text_primary;
  margin: 4px;
  min-width: 24px;
  min-height: 24px;
  -GtkWidget-vexpand: true;
  -GtkWidget-valign: center;
  transition: all 0.15s ease-out;
}
button.module:hover {
  background-color: alpha(@surface2, 0.9);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
}
button.module:active {
  background-color: @shell_bg_active;
  box-shadow: 0 2px 8px @shadow;
}

/* ============================================================
 * Module Pill — tighter variant for metrics
 * ============================================================ */
button.module_pill {
  padding: 0px 10px;
  margin: 4px 2px;
  border-radius: 18px;
  background-color: alpha(@theme_bg_color, 0.85);
  border: 1px solid @shell_border;
  box-shadow: 0 4px 16px @shadow;
  color: @text_muted;
  font-size: 11px;
  min-width: 0px;
  min-height: 0px;
  -GtkWidget-vexpand: true;
  -GtkWidget-valign: center;
  transition: all 0.15s ease-out;
}
button.module_pill:hover {
  background-color: alpha(@surface2, 0.9);
  color: @text_primary;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
}
button.module_pill:active {
  background-color: @shell_bg_active;
  box-shadow: 0 2px 8px @shadow;
}

/* ============================================================
 * Text Widgets — clickable info pills
 * ============================================================ */
button.text_widget {
  padding: 2px 10px;
  margin: 4px 2px;
  border-radius: 12px;
  background-color: alpha(@theme_bg_color, 0.75);
  border: 1px solid @shell_border;
  box-shadow: 0 4px 16px @shadow;
  color: @text_muted;
  min-width: 0px;
  min-height: 0px;
  font-size: 12px;
  -GtkWidget-vexpand: true;
  -GtkWidget-valign: center;
  transition: all 0.15s ease-out;
}
button.text_widget:hover {
  background-color: alpha(@surface2, 0.85);
  color: @text_primary;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
}
button.text_widget:active {
  background-color: @shell_bg_active;
  box-shadow: 0 2px 8px @shadow;
}

/* Separator dot between text widgets */
label.text_sep {
  color: rgba(166, 173, 200, 0.3);
  font-size: 8px;
  padding: 0px 2px;
}

/* ============================================================
 * Clock — prominent, bold
 * ============================================================ */
button.text_clock {
  padding: 2px 10px;
  margin: 1px 3px;
  border-radius: 6px;
  background-color: transparent;
  color: @text_primary;
  font-size: 13px;
  font-weight: bold;
  min-width: 0px;
  min-height: 0px;
  -GtkWidget-vexpand: true;
  -GtkWidget-valign: center;
}
button.text_clock:hover {
  background-color: alpha(@surface2, 0.4);
}

button#clock {
  font-size: 13px;
  font-weight: bold;
  padding: 0px 12px;
  color: @text_primary;
  min-height: 0px;
  transition: all 0.15s ease-out;
}
button#clock:hover {
  background-color: @shell_bg_hover;
}

/* ============================================================
 * Media Text — italic when playing
 * ============================================================ */
button.text_media {
  padding: 2px 8px;
  margin: 1px 3px;
  border-radius: 6px;
  background-color: transparent;
  color: @text_muted;
  font-size: 12px;
  min-width: 0px;
  min-height: 0px;
  -GtkWidget-vexpand: true;
  -GtkWidget-valign: center;
}
button.text_media:hover {
  background-color: alpha(@surface2, 0.4);
  color: @text_primary;
}

/* ============================================================
 * System Metrics Text — monospace for alignment
 * ============================================================ */
button.text_metric {
  padding: 2px 8px;
  margin: 1px 3px;
  border-radius: 6px;
  background-color: transparent;
  color: @text_muted;
  font-size: 11px;
  font-family: monospace;
  min-width: 0px;
  min-height: 0px;
  -GtkWidget-vexpand: true;
  -GtkWidget-valign: center;
}
button.text_metric:hover {
  background-color: alpha(@surface2, 0.4);
  color: @text_primary;
}

/* Status indicator — colored dot before text */
label.status_dot {
  font-size: 8px;
  padding-right: 4px;
}

/* Urgent/warning state */
button.text_urgent {
  color: @urgent;
}
button.text_urgent:hover {
  background-color: rgba(243, 139, 168, 0.15);
}
