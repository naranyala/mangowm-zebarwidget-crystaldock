#Api2
# modes/css-popups.config — Popup and menu CSS styles

#CSS

/* ============================================================
 * Detail Popup Panels — dropdown from bar
 * ============================================================ */
window.detail_popup {
  background: rgba(0, 0, 0, 0);
  padding: 12px;
}

grid.detail_grid {
  margin: 5px;
  padding: 16px;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background-color: alpha(@theme_bg_color, 0.95);
  -GtkWidget-direction: bottom;
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.05);
}

label.detail_header {
  font-size: 13px;
  font-weight: bold;
  color: @accent;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  -GtkWidget-hexpand: true;
}

label.detail_value {
  font-family: 'Noto Sans Mono', monospace;
  font-size: 12px;
  color: @text_primary;
  padding: 8px 0px;
  -GtkWidget-hexpand: true;
}

label.detail_hint {
  font-size: 10px;
  color: @text_muted;
  padding-top: 6px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  -GtkWidget-hexpand: true;
}

grid.detail_button_row {
  -GtkWidget-hexpand: true;
  -GtkWidget-direction: right;
}

grid.detail_button_row button {
  padding: 4px 8px;
  margin: 2px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 6px;
  background-color: rgba(49, 50, 68, 0.5);
  color: @text_primary;
}

grid.detail_button_row button:hover {
  background-color: rgba(69, 71, 90, 0.7);
  border-color: @accent;
}

scale.detail_slider {
  -GtkWidget-direction: right;
  margin: 4px 0px;
}

progressbar.detail_progress trough {
  min-height: 6px;
  border-radius: 3px;
  background-color: rgba(30, 30, 46, 0.4);
  border: 1px solid rgba(69, 71, 90, 0.3);
}

progressbar.detail_progress progress {
  min-height: 6px;
  border-radius: 3px;
  background-color: @success;
}

/* ============================================================
 * Session Popup
 * ============================================================ */
window#SessionPopup {
  background: rgba(0, 0, 0, 0);
  -GtkWidget-direction: right;
  padding: 5px;
}

grid#SessionPopup {
  -GtkWidget-direction: bottom;
  -GtkWidget-hexpand: true;
  margin: 5px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  padding: 10px;
  background-color: alpha(@theme_bg_color, 0.95);
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.6);
}

/* ============================================================
 * Workspace Grid (popup)
 * ============================================================ */
grid#ws_grid {
  -GtkWidget-direction: right;
  padding: 4px;
}

button.ws_button {
  min-width: 28px;
  min-height: 28px;
  border-radius: 6px;
  padding: 4px;
  margin: 2px;
  background-color: rgba(49, 50, 68, 0.6);
  color: alpha(@text_primary, 0.6);
  font-size: 11px;
}

button.ws_button:hover {
  background-color: rgba(69, 71, 90, 0.7);
  color: @text_primary;
}

/* ============================================================
 * Dock Popup (for non-inline mode)
 * ============================================================ */
window.dock_popup {
  background: rgba(0, 0, 0, 0);
  padding: 12px;
}

grid.dock_grid {
  background-color: rgba(30, 30, 46, 0.92);
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 8px 12px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
  -GtkWidget-direction: right;
}
