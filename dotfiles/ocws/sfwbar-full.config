#Api2

# SFWBar — Noctalia-inspired comprehensive status bar
# Full-featured bar with all available widgets
Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "34px"

switcher { disable = true }

Function SfwbarInit() {}

bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # --- Left: Launcher + Workspaces ---
  widget "launcher.widget"
  widget "workspaces.widget"

  # --- Center: Clock ---
  label { css = "* { -GtkWidget-hexpand: true; }" }
  widget "clock.widget"
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: All System Modules ---
  widget "media-player.widget"
  widget "tray.widget"
  widget "network-bandwidth.widget"
  widget "bluetooth.widget"
  widget "volume-text.widget"
  widget "brightness-text.widget"
  widget "battery-text.widget"
  widget "cpu-monitor.widget"
  widget "memory-monitor.widget"
  widget "temperature.widget"
  widget "ocws-control-center.widget"
}

# --- User Overlay Config ---
# Edit ~/.config/ocws/user.config for personal changes — this file gets overwritten on update
include("user.config")

# --- Theme CSS (must be before #CSS to load as config directive) ---
include("theme.css")

# --- CSS Tokens (single source of truth for colors) ---
include("tokens.css")
