#Api2

# Noctalia-style floating centered bar
Theme = "Adwaita-dark"
Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "34px"

switcher { disable = true }

placer {
  xorigin = 5
  yorigin = 5
  xstep = 5
  ystep = 5
  children = true
}

Function SfwbarInit() {}

bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # --- Left: Launcher + Workspaces ---
  widget "launcher.widget"

  pager {
    style = "pager"
    rows = 1
    pins = "1","2","3","4","5","6","7","8","9"
    preview = true
    primary_axis = rows
    action[Drag] = WorkspaceActivate()
  }

  # --- Center: Clock ---
  label { css = "* { -GtkWidget-hexpand: true; }" }
  widget "clock.widget"
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: System Tray + Modules ---
  widget "tray.widget"
  widget "media.widget"
  widget "network.widget"
  widget "volume.widget"
  widget "battery.widget"
  widget "session.widget"
}
