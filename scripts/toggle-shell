#!/bin/bash
# toggle-shell — Switch between shell modes: doublepanel, crystaldock, minimal, dms, noctalia, tworow, lxqt-*
#
# Env vars (read at switch time, written to env.config):
#   OCWS_BAR_THICKNESS  — single-bar thickness (default: 34px)
#   OCWS_TOP_SIZE       — top bar height in doublepanel mode (default: 32)
#   OCWS_BOTTOM_SIZE    — bottom bar height in doublepanel mode (default: 40)

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR points to the real repo scripts/ directory
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Centralized error handling + desktop notifications (ocws-notify / mako / dunst)
source "$SCRIPT_DIR/lib/ocws-err.sh"
ocws_enable_strict

OCWS_DIR="$HOME/.config/ocws"
CFG="$OCWS_DIR/mode"
mkdir -p "$OCWS_DIR"

# Available modes
declare -A MODES=(
    ["doublepanel"]="labwc + double-panel sfwbar (top status bar + bottom dock/taskbar)"
    ["crystaldock"]="labwc + sfwbar statusbar + crystal-dock"
    ["minimal"]="labwc + minimal sfwbar (clock, volume, battery, tray)"
    ["dms"]="labwc + dankmaterialshell"
    ["noctalia"]="labwc + noctalia shell"
    ["fltk-panel"]="labwc + fltk top panel + bottom icon dock (C++)"
    ["fltk-panel-zig"]="labwc + fltk-zig-shell (merged panel + dock, single binary)"
    ["tworow"]="labwc + lxqt-panel (top) + sfwbar 2-row taskbar (bottom)"
    ["lxqt-classic"]="labwc + lxqt-panel bottom (classic desktop) + sfwbar top status"
    ["lxqt-minimal"]="labwc + lxqt-panel top (tray+clock) + sfwbar minimal"
    ["lxqt-standalone"]="labwc + lxqt-panel standalone (no sfwbar)"
    ["lxqt-dual-lxqt"]="labwc + dual lxqt-panels (top+bottom, no sfwbar)"
    ["lxqt-vertical"]="labwc + lxqt-panel right (vertical) + sfwbar top status"
    ["lxqt-bottom"]="labwc + lxqt-panel bottom + sfwbar top status"
)

if [ -n "${1:-}" ]; then
    MODE="$1"
    MODE="${MODE#labwc-}"

    if [ -z "${MODES[$MODE]+x}" ]; then
        echo "Usage: $0 <mode>"
        echo ""
        echo "Modes:"
        for mode in "${!MODES[@]}"; do
            echo "  $mode  ${MODES[$mode]}"
        done
        exit 1
    fi

    NEW="$MODE"
else
    echo "Usage: $0 <mode>"
    echo ""
    echo "Modes:"
    for mode in "${!MODES[@]}"; do
        echo "  $mode  ${MODES[$mode]}"
    done
    exit 1
fi

CURRENT="$(cat "$CFG" 2>/dev/null || echo crystaldock)"

echo "Current shell mode: $CURRENT"
echo "Switching to: $NEW"

# Kill existing shells
for p in crystal-dock sfwbar noctalia dms lxqt-panel fltk-panel fltk-dock fltk-cpp-shell; do
    if pgrep -x "$p" >/dev/null; then
        echo "Stopping $p..."
        pkill -x "$p"
    fi
done

# Wait for processes to exit (polling loop instead of fixed sleep)
for _ in $(seq 1 30); do
    alive=false
for p in crystal-dock sfwbar noctalia dms lxqt-panel fltk-panel fltk-dock fltk-cpp-shell; do
        pgrep -x "$p" >/dev/null 2>&1 && alive=true
    done
    $alive || break
    sleep 0.1
done

# Clean crystal-dock IPC artifacts (Qt uses a hashed string, not the app name)
rm -f /tmp/qipc_sharedmemory_* /tmp/qipc_systemsem_* /dev/shm/qipc_sharedmemory_* /dev/shm/qipc_systemsem_* 2>/dev/null

# Validate configs based on mode
case "$NEW" in
    doublepanel|crystaldock|minimal|tworow|lxqt-classic|lxqt-minimal|lxqt-standalone|lxqt-dual-lxqt|lxqt-vertical|lxqt-bottom)
        # Check for modular configs
        if [ -d "$PROJECT_DIR/dotfiles/ocws/modes" ]; then
            echo "Using modular config system"
            # Copy modes directory to user config
            mkdir -p "$OCWS_DIR/modes"
            cp -r "$PROJECT_DIR/dotfiles/ocws/modes/"* "$OCWS_DIR/modes/" 2>/dev/null || true
        elif [ ! -f "$OCWS_DIR/ocws.config" ] && [ ! -f "$OCWS_DIR/sfwbar-full.config" ]; then
            ocws_die "toggle-shell: No OCWS config found in $OCWS_DIR (run install.sh first)"
        fi
        ;;
esac

# Generate env.config from OCWS_* env vars (read by sfwbar configs)
if [ "$NEW" = "doublepanel" ] || [ "$NEW" = "crystaldock" ] || [ "$NEW" = "minimal" ] || [ "$NEW" = "tworow" ] || [[ "$NEW" == lxqt-* ]]; then
    cat > "$OCWS_DIR/env.config" <<-EOF
# env.config — generated by toggle-shell $(date +%Y-%m-%dT%H:%M:%S)
Set OCWS_BAR_THICKNESS = "${OCWS_BAR_THICKNESS:-34px}"
Set OCWS_TOP_SIZE = "${OCWS_TOP_SIZE:-32}"
Set OCWS_BOTTOM_SIZE = "${OCWS_BOTTOM_SIZE:-40}"
EOF
fi

# Start new configuration
case "$NEW" in
    dms)
        echo "Starting dms..."
        if command -v dms >/dev/null 2>&1; then
            nohup dms run >/dev/null 2>&1 &
            echo "Started dms"
        else
            ocws_die "toggle-shell: dms is not installed"
        fi
        ;;
    noctalia)
        echo "Starting noctalia..."
        if command -v noctalia >/dev/null 2>&1; then
            nohup noctalia >/dev/null 2>&1 &
            echo "Started noctalia"
        else
            ocws_die "toggle-shell: noctalia is not installed"
        fi
        ;;
    fltk-panel)
        echo "Starting fltk-panel + fltk-dock (C++)..."
        if command -v fltk-panel >/dev/null 2>&1; then
            nohup fltk-panel >/dev/null 2>&1 &
            echo "Started fltk-panel"
        else
            echo "warning: fltk-panel not found — build with: cd src/shells/fltk-panel && make"
        fi
        if command -v fltk-dock >/dev/null 2>&1; then
            nohup fltk-dock >/dev/null 2>&1 &
            echo "Started fltk-dock"
        fi
        ;;
    fltk-panel-zig)
        echo "Starting fltk-zig-shell (merged panel + dock)..."
        if command -v fltk-zig-shell >/dev/null 2>&1; then
            nohup fltk-zig-shell >/dev/null 2>&1 &
            echo "Started fltk-zig-shell"
        else
            echo "warning: fltk-zig-shell not found — build with: cd src/shells/fltk-dock-zig && zig build"
        fi
        ;;
    doublepanel)
        echo "Starting OCWS (double-panel sfwbar)..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh
        pkill -x sfwbar 2>/dev/null || true
        sleep 0.2
        # Use modular config if available
        if [ -f "$OCWS_DIR/modes/dual.mode" ]; then
            nohup sfwbar -f "$OCWS_DIR/modes/dual.mode" >/dev/null 2>&1 &
            echo "Started sfwbar (modular: dual.mode)"
        else
            nohup sfwbar -f "$OCWS_DIR/ocws.config" >/dev/null 2>&1 &
            echo "Started sfwbar (ocws.config)"
        fi
        ;;
    crystaldock)
        echo "Starting sfwbar statusbar + crystal-dock..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh
        pkill -x sfwbar 2>/dev/null || true
        sleep 0.2
        # Use modular config if available
        if [ -f "$OCWS_DIR/modes/crystaldock.mode" ]; then
            nohup sfwbar -f "$OCWS_DIR/modes/crystaldock.mode" >/dev/null 2>&1 &
            echo "Started sfwbar (modular: crystaldock.mode)"
        else
            nohup sfwbar -f "$OCWS_DIR/sfwbar-full.config" >/dev/null 2>&1 &
            echo "Started sfwbar (sfwbar-full.config)"
        fi
        if command -v crystal-dock >/dev/null 2>&1; then
            nohup crystal-dock >/dev/null 2>&1 &
            echo "Started crystal-dock"
        else
            echo "warning: crystal-dock not found — only sfwbar bar is running"
        fi
        ;;
    minimal)
        echo "Starting OCWS (minimal sfwbar)..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh
        pkill -x sfwbar 2>/dev/null || true
        sleep 0.2
        # Use modular config if available
        if [ -f "$OCWS_DIR/modes/minimal.mode" ]; then
            nohup sfwbar -f "$OCWS_DIR/modes/minimal.mode" >/dev/null 2>&1 &
            echo "Started sfwbar (modular: minimal.mode)"
        else
            ocws_die "toggle-shell: minimal mode config not found (run install.sh)"
        fi
        ;;
    tworow)
        echo "Starting sfwbar (tworow taskbar) + lxqt-panel..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh
        pkill -x sfwbar 2>/dev/null || true
        pkill -x lxqt-panel 2>/dev/null || true
        # Wait for lxqt-panel to release its layer-shell surface before relaunch
        for _ in $(seq 1 20); do
            pgrep -x lxqt-panel >/dev/null 2>&1 || break
            sleep 0.1
        done
        # Use modular config if available
        if [ -f "$OCWS_DIR/modes/tworow.mode" ]; then
            nohup sfwbar -f "$OCWS_DIR/modes/tworow.mode" >/dev/null 2>&1 &
            echo "Started sfwbar (modular: tworow.mode)"
        else
            ocws_die "toggle-shell: tworow mode config not found"
        fi
        if command -v lxqt-panel >/dev/null 2>&1; then
            # layer-shell integration is required for lxqt-panel to dock on
            # labwc; the wlroots token lets it pick the correct Wayland backend.
            QT_WAYLAND_SHELL_INTEGRATION=layer-shell \
              XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-labwc}:wlroots" \
              nohup lxqt-panel -c "$HOME/.config/lxqt/panel.conf" >/dev/null 2>&1 &
            echo "Started lxqt-panel"
        else
            echo "warning: lxqt-panel not found"
        fi
        ;;
    lxqt-classic|lxqt-minimal|lxqt-standalone|lxqt-dual-lxqt|lxqt-vertical|lxqt-bottom)
        # All lxqt-specific modes use lxqt-panel-switcher for panel config
        echo "Starting lxqt-panel mode: $NEW..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh

        # Kill existing panels
        pkill -x sfwbar 2>/dev/null || true
        pkill -x lxqt-panel 2>/dev/null || true
        for _ in $(seq 1 20); do
            pgrep -x lxqt-panel >/dev/null 2>&1 || break
            sleep 0.1
        done

        # Determine the lxqt-panel config name (strip "lxqt-" prefix for config file)
        LXQT_CONF_NAME="${NEW#lxqt-}"

        # Deploy lxqt-panel config
        if [ -f "$PROJECT_DIR/dotfiles/lxqt/modes/${LXQT_CONF_NAME}.conf" ]; then
            mkdir -p "$HOME/.config/lxqt"
            cp "$PROJECT_DIR/dotfiles/lxqt/modes/${LXQT_CONF_NAME}.conf" "$HOME/.config/lxqt/panel.conf"
            echo "Deployed lxqt-panel config: ${LXQT_CONF_NAME}.conf"
        else
            ocws_die "toggle-shell: lxqt-panel config not found: ${LXQT_CONF_NAME}.conf"
        fi

        # Start lxqt-panel
        if command -v lxqt-panel >/dev/null 2>&1; then
            QT_WAYLAND_SHELL_INTEGRATION=layer-shell \
              XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-labwc}:wlroots" \
              nohup lxqt-panel -c "$HOME/.config/lxqt/panel.conf" >/dev/null 2>&1 &
            echo "Started lxqt-panel"
        else
            echo "warning: lxqt-panel not found"
        fi

        # Start companion sfwbar if needed
        case "$NEW" in
            lxqt-classic)
                if [ -f "$OCWS_DIR/modes/lxqt-classic.mode" ]; then
                    nohup sfwbar -f "$OCWS_DIR/modes/lxqt-classic.mode" >/dev/null 2>&1 &
                    echo "Started sfwbar (lxqt-classic.mode)"
                fi
                ;;
            lxqt-minimal)
                if [ -f "$OCWS_DIR/modes/lxqt-minimal.mode" ]; then
                    nohup sfwbar -f "$OCWS_DIR/modes/lxqt-minimal.mode" >/dev/null 2>&1 &
                    echo "Started sfwbar (lxqt-minimal.mode)"
                fi
                ;;
            lxqt-standalone|lxqt-dual-lxqt)
                echo "No sfwbar companion needed for $NEW"
                ;;
            lxqt-vertical)
                if [ -f "$OCWS_DIR/modes/lxqt-vertical.mode" ]; then
                    nohup sfwbar -f "$OCWS_DIR/modes/lxqt-vertical.mode" >/dev/null 2>&1 &
                    echo "Started sfwbar (lxqt-vertical.mode)"
                fi
                ;;
            lxqt-bottom)
                if [ -f "$OCWS_DIR/modes/lxqt-bottom.mode" ]; then
                    nohup sfwbar -f "$OCWS_DIR/modes/lxqt-bottom.mode" >/dev/null 2>&1 &
                    echo "Started sfwbar (lxqt-bottom.mode)"
                fi
                ;;
        esac
        ;;
esac

# Update configuration
echo "$NEW" > "$CFG"

echo ""
echo "Shell mode switched to: $NEW"
echo "Mode description: ${MODES[$NEW]}"
